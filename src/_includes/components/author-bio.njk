{% set currentAuthor = authors[author] %}

{% if currentAuthor %}
<section class="author-section">
    <a href="/pages/profile-{{ currentAuthor.slug }}" class="author-grid author-grid-link">
        <img src="{{ currentAuthor.photo }}" alt="{{ author }}" class="author-photo">
        <div>
            <h3>Tentang {{ author }}</h3>
            <p>{{ currentAuthor.bio }}</p>
        </div>
        <span class="author-profile-cta">Lihat Profil →</span>
    </a>
</section>
{% endif %}